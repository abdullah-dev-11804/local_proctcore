/**
 * Adds a Proctoring preview entry to Quiz activity settings navigation.
 *
 * @param settings_navigation $settingsnav Settings navigation.
 * @param context $context Current context.
 * @return void
 */
function local_proctorcore_extend_settings_navigation(
    settings_navigation $settingsnav,
    context $context
): void {
    global $PAGE;

    if (!$context instanceof context_module
            || empty($PAGE->cm)
            || $PAGE->cm->modname !== 'quiz') {
        return;
    }

    $canmanage = has_capability('moodle/course:manageactivities', $context);
    $canviewreports = has_capability('mod/quiz:viewreports', $context)
        || has_capability('local/proctorcore:viewcompanyreports', context_system::instance())
        || has_capability('local/proctorcore:viewallreports', context_system::instance())
        || is_siteadmin();

    $parent = $settingsnav->find('modsettings', navigation_node::TYPE_SETTING);
    if (!$parent) {
        return;
    }

    if ($canmanage) {
        $parent->add(
            get_string('preview:button', 'local_proctorcore'),
            local_proctorcore_get_preview_url((int) $PAGE->cm->id),
            navigation_node::TYPE_SETTING,
            null,
            'local_proctorcore_preview'
        );
    }

    if ($canviewreports) {
        $parent->add(
            get_string('report:reports', 'local_proctorcore'),
            new moodle_url('/local/proctorcore/reports.php', [
                'courseid' => (int) $PAGE->course->id,
                'quizid' => (int) $PAGE->cm->instance,
            ]),
            navigation_node::TYPE_SETTING,
            null,
            'local_proctorcore_reports'
        );
    }
}

/**
 * Adds ProctorCore reports to course navigation.
 *
 * @param navigation_node $parentnode Course node.
 * @param stdClass $course Course.
 * @param context_course $context Course context.
 * @return void
 */
function local_proctorcore_extend_navigation_course(
    navigation_node $parentnode,
    stdClass $course,
    context_course $context
): void {
    global $USER;
    if (!isloggedin() || isguestuser() || empty($USER->id)) {
        return;
    }
    $parentnode->add(
        get_string('report:reports', 'local_proctorcore'),
        new moodle_url('/local/proctorcore/reports.php', ['courseid' => (int) $course->id]),
        navigation_node::TYPE_SETTING,
        null,
        'local_proctorcore_course_reports',
        new pix_icon('i/report', '')
    );
}

/**
 * Adds a personal ProctorCore report link to user profile navigation.
 *
 * @param navigation_node $parentnode User navigation node.
 * @param stdClass $user Profile user.
 * @param context_user $context User context.
 * @param stdClass $course Current course.
 * @param context_course $coursecontext Current course context.
 * @return void
 */
function local_proctorcore_extend_navigation_user(
    navigation_node $parentnode,
    stdClass $user,
    context_user $context,
    stdClass $course,
    context_course $coursecontext
): void {
    global $USER;
    $systemcontext = context_system::instance();
    $allowed = (int) $USER->id === (int) $user->id
        || is_siteadmin($USER)
        || has_capability('local/proctorcore:viewcompanyreports', $systemcontext)
        || has_capability('local/proctorcore:viewallreports', $systemcontext);
    if (!$allowed) {
        return;
    }
    $parentnode->add(
        get_string('report:myreports', 'local_proctorcore'),
        new moodle_url('/local/proctorcore/reports.php', ['userid' => (int) $user->id]),
        navigation_node::TYPE_SETTING,
        null,
        'local_proctorcore_user_reports',
        new pix_icon('i/report', '')
    );
}
