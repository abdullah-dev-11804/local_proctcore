/**
 * Creates or returns the ProctorCore session linked to a quiz attempt.
 *
 * @param int $attemptid Quiz attempt id.
 * @return \stdClass Local ProctorCore session record.
 */
function local_proctorcore_create_session_for_attempt(int $attemptid): \stdClass {
    $service = new \local_proctorcore\local\integration_service();
    return $service->create_session_for_attempt($attemptid);
}

/**
 * Checks whether a quiz attempt has satisfied Moodle-side proctoring gates.
 *
 * @param int $attemptid Quiz attempt id.
 * @param int $userid User id.
 * @return bool
 */
function local_proctorcore_is_attempt_allowed(int $attemptid, int $userid): bool {
    $repository = new \local_proctorcore\local\session_repository();
    $session = $repository->get_by_attempt_id($attemptid);

    if (!$session || (int) $session->userid !== $userid) {
        return false;
    }

    return in_array($session->status, ['active', 'completed'], true)
        && $session->techcheckstatus === 'passed'
        && in_array($session->identitystatus, ['passed', 'notrequired'], true);
}

/**
 * Returns the user's active IOMAD company id when IOMAD is available.
 *
 * @param int $userid User id.
 * @param int $courseid Optional course id.
 * @return int Company id, or 0 for normal Moodle/global context.
 */
function local_proctorcore_get_user_companyid(int $userid, int $courseid = 0): int {
    return (new \local_proctorcore\local\tenant_resolver())
        ->resolve_company_id($userid, $courseid);
}

/**
 * Records a browser heartbeat for an active proctoring session.
 *
 * @param int $sessionid Local ProctorCore session id.
 * @param int $userid Current Moodle user id.
 * @return array
 */
function local_proctorcore_record_heartbeat(int $sessionid, int $userid): array {
    return (new \local_proctorcore\local\connection_recovery_service())
        ->heartbeat($sessionid, $userid);
}

/**
 * Resumes the original Moodle quiz attempt after a brief connection loss.
 *
 * @param int $attemptid Moodle quiz attempt id.
 * @param int $userid Current Moodle user id.
 * @return array Resume response.
 */
function local_proctorcore_resume_attempt(int $attemptid, int $userid): array {
    return (new \local_proctorcore\local\connection_recovery_service())
        ->resume_attempt($attemptid, $userid);
}

/**
 * Builds the secure reconnect URL for the current user.
 *
 * @param int $attemptid Moodle quiz attempt id.
 * @return moodle_url
 */
function local_proctorcore_get_reconnect_url(int $attemptid): moodle_url {
    return new moodle_url('/local/proctorcore/reconnect.php', [
        'attemptid' => $attemptid,
        'sesskey' => sesskey(),
    ]);
}

/**
 * Loads the candidate-side heartbeat module on a proctored attempt page.
 *
 * Dev 1 or the quiz access-rule plugin should call this after the session is active.
 *
 * @param int $sessionid Local ProctorCore session id.
 * @return void
 */
function local_proctorcore_require_heartbeat(int $sessionid): void {
    global $PAGE;

    $interval = (int) get_config('local_proctorcore', 'heartbeatintervalsecs');
    $interval = min(60, max(5, $interval > 0 ? $interval : 15));

    $PAGE->requires->js_call_amd('local_proctorcore/session_heartbeat', 'init', [[
        'sessionId' => $sessionid,
        'intervalSeconds' => $interval,
    ]]);
}


/**
 * Loads Section 1.1 browser camera/microphone capture on an active Quiz attempt.
 *
 * @param int $sessionid Local ProctorCore session id.
 * @return void
 */
